DOMAIN=example.org
HTTP_PORT=8080
HTTPS_PORT=8443
# Inspect the gateway of the external Podman routing network.
CONTAINER_DNS_RESOLVER=10.89.0.1

# Resolve and review immutable digests before deployment.
NGINX_IMAGE=docker.io/library/nginx@sha256:<digest>
CERTBOT_IMAGE=docker.io/certbot/dns-cloudflare@sha256:<digest>
CROWDSEC_IMAGE=docker.io/crowdsecurity/crowdsec@sha256:<digest>
